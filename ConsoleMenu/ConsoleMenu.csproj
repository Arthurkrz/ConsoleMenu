<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
	<OutputType>Library</OutputType>
	<PackageId>1.0.0</PackageId>
	<Authors>ArthurK</Authors>
	<Description>A flexible and extensible console menu toolkit for .NET applications that support both complex and simple functions.</Description>
	<PackageTags>console menu cli toolkit dotnet</PackageTags>
	<AssemblyName>ConsoleMenu</AssemblyName>
	<RootNamespace>ConsoleMenu</RootNamespace>
	<GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="8.0.0" />
  </ItemGroup>

</Project>
